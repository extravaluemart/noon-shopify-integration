# ─── NOON CREDENTIALS ───────────────────────────────────────────────
# From your store_credentials.json downloaded in Noon Partner Dashboard
NOON_CLIENT_ID=your_client_id_here
NOON_CLIENT_SECRET=your_client_secret_here

# From Noon Partner Dashboard → Organisation Name → Project
NOON_PROJECT_ID=PRJ000000

# The country environment for Noon API (ae, sa, eg)
NOON_ENV=ae

# Secret you enter in Noon FBPI warehouse configuration → Webhook API Key field
# Generate a strong random string, e.g.: openssl rand -hex 32
NOON_WEBHOOK_SECRET=your_webhook_secret_here

# ─── SHOPIFY CREDENTIALS ─────────────────────────────────────────────
# Your myshopify.com subdomain (without .myshopify.com)
SHOPIFY_STORE=extravaluemart

# From Shopify Admin → Settings → Apps → Develop apps → your app → API credentials
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Used to validate webhooks FROM Shopify (found in the same app settings)
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# ─── SERVER ──────────────────────────────────────────────────────────
PORT=3000

# Set to "production" on Vercel
NODE_ENV=development
