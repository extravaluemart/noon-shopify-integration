# в”Ђв”Ђв”Ђ NOON CREDENTIALS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# From your store_credentials.json (type: apijwt) downloaded in Noon Partner Dashboard
# key_id field:
NOON_CLIENT_ID=your_key_id_here
# private_key field (PEM вЂ” paste on one line with \n for newlines, or multiline in Vercel):
NOON_CLIENT_SECRET=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
# channel_identifier field:
NOON_CHANNEL_ID=yourstore@p000000.idp.noon.partners

# project_code field from credentials JSON (e.g. PRJ474943)
NOON_PROJECT_ID=PRJ000000

# The country environment for Noon API (ae, sa, eg)
NOON_ENV=ae

# Secret you enter in Noon FBPI warehouse configuration в†’ Webhook API Key field
# Generate a strong random string, e.g.: openssl rand -hex 32
NOON_WEBHOOK_SECRET=your_webhook_secret_here

# в”Ђв”Ђв”Ђ SHOPIFY CREDENTIALS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Your myshopify.com subdomain (without .myshopify.com)
SHOPIFY_STORE=extravaluemart

# From Shopify Admin в†’ Settings в†’ Apps в†’ Develop apps в†’ your app в†’ API credentials
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Used to validate webhooks FROM Shopify (found in the same app settings)
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# в”Ђв”Ђв”Ђ SERVER в